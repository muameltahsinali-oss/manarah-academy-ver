# Copy to .env.production before `npm run build` (static export embeds NEXT_PUBLIC_* at build time).
# Full URL including /api — no trailing slash.
NEXT_PUBLIC_API_URL=https://api.manarah-academy.com/api

# Optional: hostname for next/image remotePatterns (defaults to api.manarah-academy.com in next.config.ts)
# NEXT_PUBLIC_IMAGE_API_HOSTNAME=api.manarah-academy.com
